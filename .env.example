# 数据目录（默认为项目下 data）
# DATA_DIR=./data

# Embedding: local=本地 sentence-transformers, openai=OpenAI API
EMBEDDING_TYPE=local
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# LLM: openai | ollama | zhipuai
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# OPENAI（openai 时）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# 智谱 AI（zhipuai 时，key 从环境变量读取）
# ZHIPUAI_API_KEY=xxx
# ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL=glm-4-flash

# Ollama（ollama 时）
# OLLAMA_BASE_URL=http://localhost:11434

# RAG 切分与检索
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
TOP_K=5

# 爬虫
CRAWL_DELAY=1.0
USER_AGENT=Mozilla/5.0 (compatible; NovelBot/1.0)
